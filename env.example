# Database Configuration
# In production, these should be set via System Environment Variables
DB_URL=jdbc:h2:mem:genesis;DB_CLOSE_DELAY=-1
DB_USERNAME=sa
DB_PASSWORD=password

# Postgres password for the docker-compose stack. REQUIRED when running
# `docker-compose up` — Compose refuses to start if unset (no default is baked
# into docker-compose.yml). Use a strong value; this placeholder is illustrative.
POSTGRES_PASSWORD=change-me-strong-local-dev-password

# JWT Authentication
# Required. Must be at least 256 bits (32 ASCII chars) for HS256.
# Boot fails fast if unset, blank, or <32 chars.
# Generate with: openssl rand -base64 48 | tr -d '\n='
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48-min-32-chars

# JWT token expiries — OPTIONAL.
# Defaults (used when unset): access=15m, refresh=7d.
# Accept any Spring Duration string: 30s, 5m, 2h, 14d.
# JWT_ACCESS_TOKEN_EXPIRY=15m
# JWT_REFRESH_TOKEN_EXPIRY=7d

# Server Port
PORT=8080

# Storage Configuration — OPTIONAL (sensible defaults baked in)
# STORAGE_PROVIDER:        cloudinary (default) | local
#   cloudinary -> uploads go to Cloudinary (requires CLOUDINARY_* below)
#   local      -> uploads written to STORAGE_LOCAL_BASE_PATH on disk (no Cloudinary needed)
# STORAGE_RETAIN_SOURCE:   true (default) keeps the raw upload; false deletes it
#                          after tokenization (re-tokenize from original then unavailable)
# STORAGE_LOCAL_BASE_PATH: directory for the local provider. In containers, mount a
#                          persistent volume here (see docker-compose.yml).
# STORAGE_PROVIDER=cloudinary
# STORAGE_RETAIN_SOURCE=true
# STORAGE_LOCAL_BASE_PATH=./data/uploads

# Cloudinary Configuration
# Required only when STORAGE_PROVIDER=cloudinary (the default).
# Sign up at https://cloudinary.com/ to get these credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — comma-separated list of frontend origins allowed to call the API.
# Dev: optional, falls back to localhost defaults if unset.
# Prod (SPRING_PROFILES_ACTIVE=prod): REQUIRED. Boot fails loudly if unset.
# Example: https://genesis-frontend.vercel.app,https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
