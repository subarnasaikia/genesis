# Database Configuration
# In production, these should be set via System Environment Variables
DB_URL=jdbc:h2:mem:genesis;DB_CLOSE_DELAY=-1
DB_USERNAME=sa
DB_PASSWORD=password

# JWT Authentication
# Required. Must be at least 256 bits (32 ASCII chars) for HS256.
# Boot fails fast if unset, blank, or <32 chars.
# Generate with: openssl rand -base64 48 | tr -d '\n='
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48-min-32-chars

# Server Port
PORT=8080

# Cloudinary Configuration
# Sign up at https://cloudinary.com/ to get these credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — comma-separated list of frontend origins allowed to call the API.
# Dev: optional, falls back to localhost defaults if unset.
# Prod (SPRING_PROFILES_ACTIVE=prod): REQUIRED. Boot fails loudly if unset.
# Example: https://genesis-frontend.vercel.app,https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
